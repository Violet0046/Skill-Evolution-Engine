{
  "truncate_enabled": true,
  "_META": {
    "_TRUNCATE": [
      {
        "path": "toolUseResult.stdout",
        "max_head": 2048,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n",
        "keep_whole_if_is_error": true
      },
      {
        "path": "toolUseResult.stderr",
        "max_head": 2048,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n",
        "keep_whole_if_is_error": true
      },
      {
        "path": "message.content[*].content",
        "max_head": 2048,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n",
        "keep_whole_if_is_error": true,
        "empty_marker": "(empty)"
      },
      {
        "path": "message.content[*].text",
        "max_head": 6144,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n"
      },
      {
        "path": "attachment.stdout",
        "max_head": 2048,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n",
        "keep_whole_if_is_error": true
      },
      {
        "path": "attachment.stderr",
        "max_head": 2048,
        "max_tail": 1024,
        "marker": "\n…[truncated, {n} bytes omitted]…\n",
        "keep_whole_if_is_error": true
      }
    ]
  },
  "user_command": {
    "drop": [
      "type",
      "promptId",
      "sessionId",
      "permissionMode",
      "entrypoint",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "isMeta",
      "cwd"
    ]
  },
  "user_input": {
    "drop": [
      "type",
      "message.content[*].type",
      "sessionId",
      "entrypoint",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "isMeta",
      "agentId",
      "cwd"
    ]
  },
  "tool_result": {
    "drop": [
      "type",
      "message.content[*].type",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "isMeta",
      "cwd"
    ]
  },
  "ai_text": {
    "drop": [
      "type",
      "message.content[*].type",
      "message.model",
      "message.usage",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "ai_tool_call": {
    "drop": [
      "type",
      "message.content[*].type",
      "message.model",
      "message.usage",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "attachment.hook_success": {
    "drop": [
      "type",
      "sessionId",
      "attachment.content",
      "attachment.toolUseID",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "attachment.async_hook_response": {
    "drop": [
      "type",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "attachment.hook_blocking_error": {
    "drop": [
      "type",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "attachment.hook_non_blocking_error": {
    "drop": [
      "type",
      "sessionId",
      "isSidechain",
      "userType",
      "version",
      "gitBranch",
      "entrypoint",
      "cwd"
    ]
  },
  "ai-title": {
